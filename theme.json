  "styles": {
    "blocks": {
      "core/cover": {
        "spacing": {
          "blockGap": "20px"
        }
      },
      "core/group": {
        "spacing": {
          "blockGap": "20px"
        }
      },
      "core/buttons": {
        "spacing": {
          "blockGap": "20px"
        }
      },
      "core/navigation": {
        "elements": {
          "link": {
            ":hover": {
              "typography": {
                "textDecoration": "underline"
              }
            },
            "typography": {
              "fontFamily": "var(--wp--preset--font-family--raleway)",
              "fontSize": "var(--wp--preset--font-size--small)",
              "fontWeight": "700",
              "textTransform": "uppercase"
            }
          }
        },
        "spacing": {
          "blockGap": "1.5rem"
        }
      },
      "core/post-navigation-link": {
        "typography": {
          "fontWeight": "700"
        }
      },
      "core/post-title": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--x-large)"
        }
      },
      "core/separator": {
        "color": {
          "background": "var(--wp--preset--color--red)"
        }
      },
      "core/site-title": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--medium)"
        }
      }
    },
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--contrast)"
    },
    "css": "footer [data-wpml='language-item']:first-of-type {\n\n    margin-bottom: 15px !important;\n}",
    "elements": {
      "button": {
        ":hover": {
          "border": {
            "color": "var(--wp--preset--color--secondary)"
          }
        },
        "border": {
          "color": "var(--wp--preset--color--transparent)",
          "radius": "4px",
          "style": "solid",
          "width": "4px"
        },
        "color": {
          "background": "var(--wp--preset--color--red)",
          "text": "var(--wp--preset--color--contrast)"
        },
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--20)",
            "right": "var(--wp--preset--spacing--50)",
            "bottom": "var(--wp--preset--spacing--20)",
            "left": "var(--wp--preset--spacing--50)"
          }
        },
        "shadow": "var(--wp--preset--shadow--natural)",
        "typography": {
          "fontSize": "var(--wp--preset--font-size--medium)",
          "fontWeight": "700"
        }
      },
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--raleway)",
          "fontWeight": "400",
          "textTransform": "uppercase"
        }
      },
      "link": {
        ":active": {
          "color": {
            "text": "var(--wp--preset--color--contrast)"
          }
        },
        ":focus": {
          "color": {
            "text": "var(--wp--preset--color--contrast)"
          }
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--contrast)"
          },
          "typography": {
            "textDecoration": "none"
          }
        },
        "color": {
          "text": "var(--wp--preset--color--contrast)"
        }
      }
    },
    "spacing": {
      "blockGap": "20px",
      "padding": {
        "left": "var(--wp--preset--spacing--60)",
        "right": "var(--wp--preset--spacing--60)"
      }
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--lora)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.7"
